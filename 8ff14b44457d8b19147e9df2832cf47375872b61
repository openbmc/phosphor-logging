      "writtenOn": "2026-03-24T21:52:05Z",
      "side": 1,
      "message": "I like this check, but what happens if:\n1. BMC A creates event.\n2. event is synced to BMC B\n3. someone updates Resolved property on BMC A.",
      "revId": "8ff14b44457d8b19147e9df2832cf47375872b61",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
